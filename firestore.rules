rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /guests/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
      match /notes/{note} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
    match /staff/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /conversations/{doc} {
      allow read, write: if false;
    }
  }
}
